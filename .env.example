# ============================================
# Imani — Environment Variables Template
# Salin file ini menjadi .env dan isi nilainya
# ============================================

# URL Google Apps Script Web App (dari clasp deploy)
VITE_GAS_BACKEND_URL=https://script.google.com/macros/s/SCRIPT_ID/exec

# Base URL aplikasi (GitHub Pages)
VITE_APP_BASE_URL=https://username.github.io/imani-frontend

# Nama repo untuk base path Vite
VITE_REPO_NAME=imani-frontend

# ─── Firebase Authentication ──────────────────────────
# Dapatkan dari Firebase Console → Project Settings → Web App
VITE_FIREBASE_API_KEY=AIza...
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef

# ─── GAS Script Properties (atur di GAS Editor) ───────
# Project Settings → Script Properties → tambah:
#   FIREBASE_PROJECT_ID = your-project-id   (sama dengan VITE_FIREBASE_PROJECT_ID)
